#RESEARCH REPO
# 1. Stage the specific file(s) you worked on
git add "filename.py"

# 2. Lock in your changes with a milestone message
git commit -m "feat: implement core vectorized algorithm logic"

# 3. Push safely to your research repository
git push origin main

#IIK REPO
# 1. Synchronize your folder with the online portfolio state first
git pull iitk main --rebase

# 2. Stage ONLY the specific file you want to append
git add "(P)filename.py"

# 3. Commit your asset
git commit -m "feat: append completed problem solution"

# 4. Push directly to your portfolio (Safe: will NOT overwrite old files)
git push iitk main